{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/demo(?:/)?$",
      "dest": "/demo.html"
    },
    {
      "src": "/(.*)",
      "dest": "/main.html"
    }
  ]
}
