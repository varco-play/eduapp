{
  "version": 2,
  "builds": [
    {
      "src": "main.html",
      "use": "@vercel/static"
    },
    {
      "src": "demo.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/demo",
      "dest": "demo.html"
    },
    {
      "src": "/(.*)",
      "dest": "main.html"
    }
  ]
}
